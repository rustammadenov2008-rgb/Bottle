# Подключение к базе данных Neon (Vercel Postgres).
# Получить: Vercel Dashboard → Storage → Create Database → Neon Postgres
# Скопируй строку подключения из вкладки .env.local там же.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Ключ Google Gemini API для бота Gemini.
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Необязательно: имя модели Gemini. По умолчанию gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Ключ xAI API для бота Grok.
# Получить: https://console.x.ai (раздел API Keys, нужно привязать карту)
XAI_API_KEY=xai-...

# Необязательно: имя модели Grok. По умолчанию grok-4.3.
GROK_MODEL=grok-4.3
